{
  "tier": 2,
  "level": "assembly",
  "description": "Multi-entity prompts with direct IFC relations. GraphRAG should outperform Flat RAG here. Evaluates relation correctness, connectivity, and attribute fidelity.",
  "ifc_relations": ["IfcRelConnects", "IfcRelAggregates", "IfcRelAssigns", "IfcRelConnectsPortToElement"],
  "prompts": [
    {"id": "T2-MEP-001", "domain": "MEP", "prompt": "Generate a centrifugal pump connected to two pipe segments on inlet and outlet", "entities": ["IfcPump", "IfcPipeSegment", "IfcPipeSegment"], "relations": [{"type": "IfcRelConnectsPortToElement", "from": "IfcPump.InletPort", "to": "IfcPipeSegment[0]"}, {"type": "IfcRelConnectsPortToElement", "from": "IfcPump.OutletPort", "to": "IfcPipeSegment[1]"}], "constraints": ["pipe_endpoints_touch_pump_ports", "inlet_pipe_horizontal", "outlet_pipe_horizontal"]},
