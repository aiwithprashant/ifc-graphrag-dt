    {"id": "T2-MEP-005", "domain": "MEP", "prompt": "Generate a check valve between two pipe segments with flow direction marked", "entities": ["IfcValve", "IfcPipeSegment", "IfcPipeSegment"], "relations": [{"type": "IfcRelConnects", "from": "IfcPipeSegment[0]", "to": "IfcValve"}, {"type": "IfcRelConnects", "from": "IfcValve", "to": "IfcPipeSegment[1]"}], "constraints": ["unidirectional_flow", "flow_arrow_visible"]},
    {"id": "T2-MEP-006", "domain": "MEP", "prompt": "Generate a pump assembly with a strainer on the inlet pipe", "entities": ["IfcPump", "IfcFilter", "IfcPipeSegment"], "relations": [{"type": "IfcRelConnects", "from": "IfcFilter", "to": "IfcPipeSegment"}, {"type": "IfcRelConnectsPortToElement", "from": "IfcPipeSegment", "to": "IfcPump.InletPort"}], "constraints": ["strainer_upstream_of_pump", "pipe_connects_strainer_to_pump"]},
    {"id": "T2-MEP-007", "domain": "MEP", "prompt": "Generate two parallel pump assemblies sharing a common header pipe", "entities": ["IfcPump", "IfcPump", "IfcPipeSegment"], "relations": [{"type": "IfcRelConnectsPortToElement", "from": "IfcPump[0].OutletPort", "to": "IfcPipeSegment"}, {"type": "IfcRelConnectsPortToElement", "from": "IfcPump[1].OutletPort", "to": "IfcPipeSegment"}], "constraints": ["pumps_parallel_not_series", "header_pipe_collects_both_outlets"]},
    {"id": "T2-MEP-008", "domain": "MEP", "prompt": "Generate a pressure relief valve assembly with upstream isolation valve", "entities": ["IfcValve", "IfcValve", "IfcPipeSegment"], "relations": [{"type": "IfcRelConnects", "from": "IfcPipeSegment", "to": "IfcValve[isolation]"}, {"type": "IfcRelConnects", "from": "IfcValve[isolation]", "to": "IfcValve[relief]"}], "constraints": ["isolation_valve_upstream", "relief_valve_downstream"]},
    {"id": "T2-MEP-009", "domain": "MEP", "prompt": "Generate a heat exchanger with supply and return pipe connections", "entities": ["IfcHeatExchanger", "IfcPipeSegment", "IfcPipeSegment"], "relations": [{"type": "IfcRelConnectsPortToElement", "from": "IfcHeatExchanger.PrimaryInlet", "to": "IfcPipeSegment[supply]"}, {"type": "IfcRelConnectsPortToElement", "from": "IfcHeatExchanger.PrimaryOutlet", "to": "IfcPipeSegment[return]"}], "constraints": ["supply_and_return_on_same_side", "pipe_diameters_match_nozzles"]},
